# Ollama HTTP API (Python SDK Client host)
OLLAMA_HOST=http://127.0.0.1:11434

# Vision model tag (must support images), e.g. llava:7b, qwen2.5vl:latest
OLLAMA_MODEL=gemma4:31b

# Longest image edge (px) before sending to the model
MAX_IMAGE_EDGE=1280

# Seconds to wait for the vision model
OLLAMA_TIMEOUT=180

# Max upload size (bytes)
MAX_UPLOAD_BYTES=10485760

# --- 이사 견적 (/move) 참고 요금 계수 (원) ---
MOVE_BASE_WON=150000
MOVE_PER_M3_WON=120000
MOVE_PER_KM_WON=2500
MOVE_FLOOR_STEP_WON=15000
MOVE_MAX_IMAGES=6
