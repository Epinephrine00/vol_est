# Ollama HTTP API (Python SDK Client host)
OLLAMA_HOST=http://127.0.0.1:11434

# Vision model tag (must support images), e.g. llava:7b, qwen2.5vl:latest
OLLAMA_MODEL=gemma4:e2b

# Longest image edge (px) before sending to the model
MAX_IMAGE_EDGE=1280

# Seconds to wait for the vision model
OLLAMA_TIMEOUT=180

# 업로드 한도(바이트). /move 에 여러 장 올릴 때는 MOVE_MAX_UPLOAD_BYTES 와 더 큰 값이 MAX_CONTENT_LENGTH 로 쓰입니다.
MAX_UPLOAD_BYTES=10485760
# 이사 견적 다중 사진용 상한(기본 120MB). 413 이면 올리세요.
MOVE_MAX_UPLOAD_BYTES=125829120

# --- 이사 견적 (/move) 참고 요금 계수 (원) ---
# RMC config/pricing.yaml 기준:
# - base_labor_fee=120000
# - default.rate_per_m3=33000
# - distance/floor surcharge는 pricing.yaml에 없으므로 기본 0
MOVE_BASE_WON=120000
MOVE_PER_M3_WON=33000
MOVE_PER_KM_WON=0
MOVE_FLOOR_STEP_WON=0
# data/anon_* 처럼 photo_*.jpg 다수 업로드 시 상한 (VLM 한 번에 전달)
MOVE_MAX_IMAGES=30
# PDF에 넣을 썸네일 개수(견적서 용량)
MOVE_PDF_MAX_THUMBS=12
# 한글 PDF 폰트(.ttf/.ttc). 비우면 macOS AppleGothic 등 자동 탐색
# MOVE_PDF_FONT_TTF=
# MOVE_PDF_TTC_INDEX=1
# Ollama 다중 이미지 시 컨텍스트 (모델/VRAM에 맞게)
MOVE_NUM_CTX=16384
# VLM에 넘기는 JSON+user_prompt 통합 문자 수 상한
MOVE_VLM_CONTEXT_CHARS=16000
